{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug", "--", "--inspect-brk"],
      "autoAttachChildProcesses": true,
      "restart": true,
      "sourceMaps": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Worker",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:worker:debug", "--", "--inspect-brk"],
      "autoAttachChildProcesses": true,
      "restart": true,
      "sourceMaps": true,
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Debug Both",
      "configurations": ["Debug API", "Debug Worker"]
    }
  ]
}
